# ── Backend ─────────────────────────────────────────────────────
APP_SECRET=               # Required in production; strong random secret for admin/session signing

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Optional OAuth (not needed for password admin login) ────────
APP_ID=                   # Optional Kimi OAuth application ID
VITE_KIMI_AUTH_URL=       # Optional Kimi OAuth server URL (e.g. https://auth.kimi.com)
VITE_APP_ID=              # Optional OAuth application ID exposed to the browser

# ── Backend OAuth (optional) ────────────────────────────────────
KIMI_AUTH_URL=            # Optional Kimi OAuth server URL (backend)
KIMI_OPEN_URL=            # Optional Kimi Open Platform URL (e.g. https://open.kimi.com)

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # Union ID of the app creator; this user gets role "admin" on first login

# ── Client Admin ────────────────────────────────────────────────
ADMIN_PASSWORD_HASH=      # Required in production; generate with `npm run admin:hash`
ADMIN_TOTP_SECRET=        # Optional; generate with `npm run admin:totp` to require authenticator codes
ADMIN_PASSWORD=           # Development fallback only; do not use in production
